{
  "name": "react-mock-component",
  "version": "5.0.0",
  "description": "Create type safe mock React components to use in tests",
  "keywords": [
    "tdd",
    "react",
    "spy",
    "stub",
    "mock",
    "test",
    "typescript"
  ],
  "author": "Andrei Picus",
  "license": "MIT",
  "homepage": "https://github.com/NiGhTTraX/react-mock-component",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "import": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.tsx --format cjs,esm --dts --clean --tsconfig tsconfig.build.json --attw --publint",
    "prepublishOnly": "pnpm run build",
    "release": "standard-version",
    "lint": "eslint --quiet .",
    "test": "vitest --coverage",
    "posttest": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "lodash": "~4.18.0"
  },
  "peerDependencies": {
    "@types/react": "^18.0.0 || ^19.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "~0.18.2",
    "@nighttrax/eslint-config-tsx": "~12.4.0",
    "@testing-library/dom": "~10.4.1",
    "@testing-library/react": "~16.3.2",
    "@types/lodash": "~4.17.24",
    "@types/react": "~19.2.14",
    "@types/react-dom": "~19.2.3",
    "@vitejs/plugin-react": "~6.0.1",
    "@vitest/coverage-v8": "~4.1.0",
    "eslint": "~9.39.4",
    "jsdom": "~29.1.0",
    "publint": "~0.3.19",
    "prettier": "~3.8.1",
    "react": "~19.2.4",
    "react-dom": "~19.2.4",
    "standard-version": "~9.5.0",
    "tsdown": "~0.22.0",
    "typescript": "~6.0.0",
    "vite": "~8.0.3",
    "vitest": "~4.1.2"
  },
  "packageManager": "pnpm@11.1.3"
}
